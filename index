<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="FitTrack" />
  <meta name="theme-color" content="#f9f8f6" />
  <title>FitTrack</title>

  <!-- PWA Manifest inline -->
  <script>
    const manifest = {
      name: "FitTrack — 12 Week Plan",
      short_name: "FitTrack",
      start_url: "./",
      display: "standalone",
      background_color: "#f9f8f6",
      theme_color: "#D4A373",
      orientation: "portrait",
      icons: [
        { src: "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='25' fill='%23FDFBF7'/><text y='.95em' font-size='68' x='15'>🎀</text></svg>", sizes: "192x192", type: "image/svg+xml" }
      ]
    };
    const blob = new Blob([JSON.stringify(manifest)], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const link = document.createElement('link');
    link.rel = 'manifest'; link.href = url;
    document.head.appendChild(link);
  </script>

  <!-- Apple touch icon (เปลี่ยนไอคอนให้คลีนและดูซอฟต์) -->
  <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='25' fill='%23FDFBF7'/><text y='.95em' font-size='68' x='15'>🎀</text></svg>" />

  <!-- React + Babel from CDN -->
  <script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    body { 
      background: linear-gradient(135deg, #fdfbfb 0%, #f4f0eb 100%); 
      min-height: 100vh; 
      font-family: 'Prompt', -apple-system, sans-serif; 
    }
    input, select, textarea { font-family: inherit; }
    ::-webkit-scrollbar { display: none; }
    option { background: white; color: #333; }
    
    .fade-in { animation: fadeIn 0.4s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect } = React;

    // ── TOKENS (ปรับสีให้คลีน หรูหรา สไตล์เอิร์ธโทน)
    const T = {
      bgGrad: "linear-gradient(135deg, #fdfbfb 0%, #f4f0eb 100%)",
      accent: "#D4A373", // สีเบจ/น้ำตาลอ่อน
      mint: "#9FA692",   // สีเขียวเสจ
      kbody: "#D4A3A3",  // สีชมพูตุ่น
      gold: "#C9A66B",   // สีทองหม่น
      purple: "#A89CBA",
      text: "#4A4A4A",
      muted: "#9E9E9E",
      dim: "#D1D1D1",
      shimmer: "linear-gradient(135deg, rgba(255,255,255,1) 0%, rgba(248,245,242,0.6) 100%)",
    };

    const PHASES = ["Week 1–2","Week 3–4","Week 5–8","Week 9–12"];
    const DAYS = ["จันทร์","อังคาร","พุธ","พฤหัส","ศุกร์","เสาร์","อาทิตย์"];
    const WORKOUT_TYPES = ["Full Body Pilates","Upper Body","Lower Body / Glutes","HIIT","Abs & Core","Cardio","Recovery","พัก"];
    const CHANNELS = ["KBodySculpt 🌸","Growingannanas 🍍","ทั้งสอง"];
    const MUSCLE_GROUPS = ["Glutes","Quads","Hamstrings","Core","Chest","Back","Shoulders","Arms","Full Body","Inner Thigh"];
    const INTENSITY = ["เบามาก","เบา","ปานกลาง","หนัก","หนักมาก"];
    const CLOTHES_FIT = ["คับมาก","คับ","พอดีตึง","พอดี","หลวม"];
    const CHECKPOINTS = ["Week 0 (เริ่ม)","Week 2","Week 4","Week 6","Week 8","Week 10","Week 12"];
    const PHASE_TARGETS = [575, 780, 1075, 1270];

    // ── STORAGE
    const load = (key) => { try { const v = localStorage.getItem("ft_"+key); return v ? JSON.parse(v) : null; } catch { return null; } };
    const save = (key, val) => { try { localStorage.setItem("ft_"+key, JSON.stringify(val)); } catch {} };

    // ── COMPONENTS
    const Badge = ({ children, color = T.accent }) => (
      <span style={{ fontSize:10, fontWeight:500, color, background:`${color}15`, borderRadius:20, padding:"4px 10px", border:`1px solid ${color}30` }}>{children}</span>
    );

    const Inp = ({ label, type="text", value, onChange, placeholder, min, max }) => (
      <div style={{ marginBottom:12 }}>
        {label && <div style={{ fontSize:11, color:T.muted, marginBottom:6, fontWeight:500, letterSpacing:"0.05em" }}>{label}</div>}
        <input type={type} value={value} onChange={e=>onChange(e.target.value)} placeholder={placeholder} min={min} max={max}
          style={{ width:"100%", background:"rgba(255,255,255,0.9)", border:"1px solid rgba(0,0,0,0.05)", borderRadius:12, padding:"12px 14px", color:T.text, fontSize:14, outline:"none", boxSizing:"border-box", transition:"all 0.2s" }} />
      </div>
    );

    const Sel = ({ label, value, onChange, options }) => (
      <div style={{ marginBottom:12 }}>
        {label && <div style={{ fontSize:11, color:T.muted, marginBottom:6, fontWeight:500, letterSpacing:"0.05em" }}>{label}</div>}
        <select value={value} onChange={e=>onChange(e.target.value)}
          style={{ width:"100%", background:"rgba(255,255,255,0.9)", border:"1px solid rgba(0,0,0,0.05)", borderRadius:12, padding:"12px 14px", color:T.text, fontSize:14, outline:"none", transition:"all 0.2s" }}>
          <option value="">— เลือก —</option>
          {options.map(o=><option key={o} value={o}>{o}</option>)}
        </select>
      </div>
    );

    const StatBox = ({ label, value, unit, color=T.text }) => (
      <div style={{ background:"rgba(255,255,255,0.85)", borderRadius:16, padding:"14px 10px", textAlign:"center", border:"1px solid rgba(0,0,0,0.03)", flex:1, boxShadow:"0 4px 15px rgba(0,0,0,0.02)" }}>
        <div style={{ fontSize:22, fontWeight:600, color, lineHeight:1 }}>{value ?? "—"}</div>
        {unit && <div style={{ fontSize:10, color:T.muted, marginTop:4 }}>{unit}</div>}
        <div style={{ fontSize:11, color:T.muted, marginTop:4 }}>{label}</div>
      </div>
    );

    // ── MAIN APP
    function App() {
      const [tab, setTab] = useState("dashboard");
      const [logs, setLogs] = useState(() => load("logs") || []);
      const [progs, setProgs] = useState(() => load("progs") || []);
      const [weeks, setWeeks] = useState(() => load("weeks") || []);
      const [showLog, setShowLog] = useState(false);
      const [showProg, setShowProg] = useState(false);
      const [showWeek, setShowWeek] = useState(false);
      const [showSettings, setShowSettings] = useState(false);
      
      const [logF, setLogF] = useState({ id:Date.now(), date:new Date().toISOString().slice(0,10), day:"", phase:"", workoutType:"", channel:"", videoUrl:"", duration:"", completed:false, intensity:"", avgHR:"", maxHR:"", calories:"", dumbbell:"", vsLastWeek:"", muscleGroups:[], prToday:false, notes:"" });
      const [progF, setProgF] = useState({ id:Date.now(), date:new Date().toISOString().slice(0,10), checkpoint:"", weight:"", chest:"", waist:"", hips:"", clothesFit:"", notes:"" });
      
      const [saved, setSaved] = useState(false);
      
      // Gemini State
      const [apiKey, setApiKey] = useState(() => load("gemini_key") || "");
      const [aiResponse, setAiResponse] = useState("");
      const [isThinking, setIsThinking] = useState(false);

      const flash = () => { setSaved(true); setTimeout(()=>setSaved(false), 1800); };
      const saveLog = () => { const u=[{...logF,id:Date.now()},...logs]; setLogs(u); save("logs",u); setShowLog(false); flash(); };
      const saveProg = () => { const u=[{...progF,id:Date.now()},...progs]; setProgs(u); save("progs",u); setShowProg(false); flash(); };
      const delLog = (id) => { const u=logs.filter(l=>l.id!==id); setLogs(u); save("logs",u); };

      const now = new Date(); const weekStart = new Date(now); weekStart.setDate(now.getDate()-now.getDay());
      const thisWeek = logs.filter(l=>new Date(l.date)>=weekStart);
      const burnWeek = thisWeek.reduce((a,l)=>a+(Number(l.calories)||0),0);
      const doneWeek = thisWeek.filter(l=>l.completed).length;
      
      const latestP = progs[0];
      const phIdx = Math.min(Math.floor(logs.length/14),3);
      const phTarget = PHASE_TARGETS[phIdx];
      const toggleM = (m) => setLogF(f=>({...f,muscleGroups:f.muscleGroups.includes(m)?f.muscleGroups.filter(x=>x!==m):[...f.muscleGroups,m]}));

      // Function เรียกใช้ Gemini API
      const askGemini = async () => {
        if (!apiKey) {
          setShowSettings(true);
          return;
        }
        setIsThinking(true);
        setAiResponse("");
        try {
          const prompt = `ในฐานะ AI Personal Trainer ส่วนตัว (พิมพ์ด้วยน้ำเสียงอบอุ่น เป็นกันเอง สุภาพ) 
          ช่วยวิเคราะห์และให้กำลังใจสั้นๆ (ประมาณ 3-4 บรรทัด) จากข้อมูลนี้: 
          สัปดาห์นี้ฉันออกกำลังกายไป ${doneWeek}/5 วัน เผาผลาญไป ${burnWeek} kcal (เป้าหมายคือ ${phTarget} kcal) 
          ล่าสุดน้ำหนักของฉันคือ ${latestP?.weight || '-'} kg`;
          
          const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
          });
          const data = await res.json();
          if(data.error) throw new Error(data.error.message);
          setAiResponse(data.candidates[0].content.parts[0].text);
        } catch (e) {
          setAiResponse("เกิดข้อผิดพลาดในการเชื่อมต่อ กรุณาตรวจสอบ API Key ของคุณครับ");
        }
        setIsThinking(false);
      };

      const card = { background:"rgba(255,255,255,0.85)", borderRadius:20, padding:"18px", marginBottom:12, border:"1px solid rgba(255,255,255,1)", boxShadow:"0 4px 20px rgba(0,0,0,0.03)" };
      const btnPrimary = (color) => ({ width:"100%", background:color, border:"none", borderRadius:16, padding:"16px", color:"white", fontSize:15, fontWeight:500, cursor:"pointer", transition:"0.2s", boxShadow:`0 4px 15px ${color}40` });

      return (
        <div style={{ background:T.bgGrad, minHeight:"100vh", color:T.text, paddingBottom:90 }}>

          {/* TOP BAR */}
          <div style={{ background:"rgba(253,251,247,0.8)", backdropFilter:"blur(20px)", WebkitBackdropFilter:"blur(20px)", borderBottom:"1px solid rgba(0,0,0,0.03)", padding:"16px 20px", position:"sticky", top:0, zIndex:50, display:"flex", alignItems:"center", justifyContent:"space-between" }}>
            <div>
              <div style={{ fontSize:18, fontWeight:600, letterSpacing:"0.02em" }}>FIT<span style={{color:T.accent}}>TRACK</span></div>
              <div style={{ fontSize:11, color:T.muted, marginTop:2 }}>Your Personal Journey</div>
            </div>
            <div style={{ display:"flex", gap:10, alignItems:"center" }}>
              {saved && <span style={{ fontSize:12, color:T.mint, fontWeight:500 }}>บันทึกสำเร็จ ✨</span>}
              <button onClick={()=>setShowSettings(!showSettings)} style={{ background:"none", border:"none", fontSize:20, cursor:"pointer" }}>⚙️</button>
            </div>
          </div>

          {/* SETTINGS MODAL */}
          {showSettings && (
            <div className="fade-in" style={{ margin:"16px", padding:"20px", background:"white", borderRadius:20, boxShadow:"0 8px 30px rgba(0,0,0,0.08)" }}>
              <div style={{ fontSize:14, fontWeight:600, marginBottom:12 }}>ตั้งค่าการเชื่อมต่อ Gemini AI</div>
              <p style={{ fontSize:12, color:T.muted, marginBottom:12 }}>ขอ API Key ฟรีได้ที่ Google AI Studio เพื่อเปิดใช้งานฟีเจอร์ผู้ช่วยโค้ชส่วนตัว</p>
              <Inp label="Gemini API Key" type="password" value={apiKey} onChange={v=>{ setApiKey(v); save("gemini_key", v); }} placeholder="AIzaSy..." />
              <button onClick={()=>setShowSettings(false)} style={btnPrimary(T.text)}>ปิดการตั้งค่า</button>
            </div>
          )}

          {/* SUB NAV */}
          <div style={{ display:"flex", background:"rgba(253,251,247,0.8)", backdropFilter:"blur(20px)", WebkitBackdropFilter:"blur(20px)", overflowX:"auto" }}>
            {[["dashboard","Overview"],["log","Workout Log"],["progress","Body Check"]].map(([k,label])=>(
              <button key={k} onClick={()=>setTab(k)}
                style={{ flex:1, border:"none", background:"none", padding:"16px 10px", fontSize:13, fontWeight:tab===k?600:400, cursor:"pointer",
                  color:tab===k?T.accent:T.muted, borderBottom:tab===k?`2px solid ${T.accent}`:"2px solid transparent", transition:"0.2s" }}>
                {label}
              </button>
            ))}
          </div>

          <div className="fade-in" style={{ maxWidth:540, margin:"0 auto", padding:"20px 16px" }}>

            {/* ── DASHBOARD ── */}
            {tab==="dashboard" && (
              <div>
                <div style={{ background:T.shimmer, borderRadius:24, padding:"24px", marginBottom:16, border:"1px solid rgba(255,255,255,1)", boxShadow:"0 8px 30px rgba(0,0,0,0.04)" }}>
                  <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
                    <div style={{ fontSize:12, color:T.muted, fontWeight:500 }}>ความคืบหน้าสัปดาห์นี้</div>
                    <Badge color={T.accent}>{PHASES[phIdx]}</Badge>
                  </div>
                  
                  <div style={{ display:"flex", gap:20, alignItems:"center" }}>
                    <div style={{ flex:1 }}>
                      <div style={{ fontSize:36, fontWeight:600, color:T.text }}>{burnWeek}</div>
                      <div style={{ fontSize:13, color:T.muted, marginBottom:10 }}>จากเป้าหมาย {phTarget} kcal</div>
                      <Badge color={T.mint}>{doneWeek}/5 วันสำเร็จ ✨</Badge>
                    </div>
                  </div>
                </div>

                <div style={{ display:"flex", gap:10, marginBottom:20 }}>
                  <StatBox label="น้ำหนักปัจจุบัน" value={latestP?.weight??"-"} unit="kg"/>
                  <StatBox label="รอบเอว" value={latestP?.waist??"-"} unit="cm"/>
                </div>

                {/* AI COACH SECTION */}
                <div style={card}>
                  <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
                    <div style={{ fontSize:14, fontWeight:600, display:"flex", alignItems:"center", gap:8 }}>
                      <span style={{fontSize:18}}>✨</span> Gemini Coach
                    </div>
                  </div>
                  
                  {aiResponse ? (
                    <div style={{ fontSize:13, color:T.text, lineHeight:1.6, background:"#FDFBF7", padding:"16px", borderRadius:16, border:`1px solid ${T.accent}30` }}>
                      {aiResponse}
                    </div>
                  ) : (
                    <p style={{ fontSize:13, color:T.muted, marginBottom:16 }}>รับคำแนะนำและกำลังใจจาก AI ประจำสัปดาห์</p>
                  )}
                  
                  <button onClick={askGemini} disabled={isThinking} style={{ ...btnPrimary(T.accent), padding:"12px", marginTop:12, opacity:isThinking?0.7:1 }}>
                    {isThinking ? "กำลังวิเคราะห์..." : (aiResponse ? "อัปเดตคำแนะนำ" : "วิเคราะห์ข้อมูลสัปดาห์นี้")}
                  </button>
                </div>

              </div>
            )}

            {/* ── LOG ── */}
            {tab==="log" && (
              <div>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
                  <div style={{ fontSize:18, fontWeight:600 }}>ประวัติการออกกำลังกาย</div>
                  <button onClick={()=>setShowLog(!showLog)}
                    style={{ background:T.text, border:"none", borderRadius:20, padding:"8px 16px", color:"white", fontSize:13, cursor:"pointer" }}>
                    {showLog?"ยกเลิก":"+ เพิ่มใหม่"}
                  </button>
                </div>

                {showLog && (
                  <div className="fade-in" style={card}>
                    <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
                      <Inp label="วันที่" type="date" value={logF.date} onChange={v=>setLogF(f=>({...f,date:v}))}/>
                      <Sel label="วัน" value={logF.day} onChange={v=>setLogF(f=>({...f,day:v}))} options={DAYS}/>
                    </div>
                    <Sel label="ประเภท" value={logF.workoutType} onChange={v=>setLogF(f=>({...f,workoutType:v}))} options={WORKOUT_TYPES}/>
                    <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
                      <Inp label="แคลอรี่ที่เผาผลาญ" type="number" value={logF.calories} onChange={v=>setLogF(f=>({...f,calories:v}))} placeholder="185"/>
                      <Inp label="เวลา (นาที)" type="number" value={logF.duration} onChange={v=>setLogF(f=>({...f,duration:v}))} placeholder="30"/>
                    </div>
                    <Inp label="โน้ตเพิ่มเติม" value={logF.notes} onChange={v=>setLogF(f=>({...f,notes:v}))} placeholder="ทำได้ดีมากวันนี้..."/>
                    
                    <label style={{ display:"flex", gap:10, alignItems:"center", fontSize:14, cursor:"pointer", marginBottom:16, marginTop:8 }}>
                      <input type="checkbox" checked={logF.completed} onChange={e=>setLogF(f=>({...f,completed:e.target.checked}))} style={{ width:18, height:18 }}/> ทำครบถ้วนสมบูรณ์
                    </label>
                    <button onClick={saveLog} style={btnPrimary(T.text)}>บันทึกข้อมูล</button>
                  </div>
                )}

                {logs.length===0 && !showLog && <div style={{ textAlign:"center", color:T.dim, padding:"40px 0" }}>ยังไม่มีข้อมูล</div>}
                {logs.map(l=>(
                  <div key={l.id} style={card}>
                    <div style={{ display:"flex", justifyContent:"space-between", marginBottom:10 }}>
                      <div style={{ fontSize:13, fontWeight:500 }}>{l.date} {l.completed && <span style={{color:T.mint, marginLeft:4}}>✓</span>}</div>
                      <button onClick={()=>delLog(l.id)} style={{ background:"none", border:"none", color:T.dim, cursor:"pointer" }}>✕</button>
                    </div>
                    <div style={{ fontSize:15, fontWeight:600, color:T.text, marginBottom:8 }}>{l.workoutType || "ไม่ได้ระบุ"}</div>
                    <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
                      {l.calories && <Badge color={T.accent}>🔥 {l.calories} kcal</Badge>}
                      {l.duration && <Badge color={T.muted}>⏱ {l.duration} นาที</Badge>}
                    </div>
                    {l.notes && <div style={{ fontSize:12, color:T.muted, marginTop:10 }}>"{l.notes}"</div>}
                  </div>
                ))}
              </div>
            )}

            {/* ── BODY PROGRESS ── */}
            {tab==="progress" && (
              <div>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
                  <div style={{ fontSize:18, fontWeight:600 }}>การเปลี่ยนแปลงของร่างกาย</div>
                  <button onClick={()=>setShowProg(!showProg)}
                    style={{ background:T.text, border:"none", borderRadius:20, padding:"8px 16px", color:"white", fontSize:13, cursor:"pointer" }}>
                    {showProg?"ยกเลิก":"+ วัดสัดส่วน"}
                  </button>
                </div>

                {showProg && (
                  <div className="fade-in" style={card}>
                    <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
                      <Inp label="วันที่" type="date" value={progF.date} onChange={v=>setProgF(f=>({...f,date:v}))}/>
                      <Sel label="Checkpoint" value={progF.checkpoint} onChange={v=>setProgF(f=>({...f,checkpoint:v}))} options={CHECKPOINTS}/>
                      <Inp label="น้ำหนัก (kg)" type="number" value={progF.weight} onChange={v=>setProgF(f=>({...f,weight:v}))} />
                      <Inp label="รอบเอว (cm)" type="number" value={progF.waist} onChange={v=>setProgF(f=>({...f,waist:v}))} />
                      <Inp label="รอบอก (cm)" type="number" value={progF.chest} onChange={v=>setProgF(f=>({...f,chest:v}))} />
                      <Inp label="รอบสะโพก (cm)" type="number" value={progF.hips} onChange={v=>setProgF(f=>({...f,hips:v}))} />
                    </div>
                    <button onClick={saveProg} style={{...btnPrimary(T.text), marginTop:12}}>บันทึกสัดส่วน</button>
                  </div>
                )}

                {progs.map(p=>(
                  <div key={p.id} style={card}>
                    <div style={{ display:"flex", justifyContent:"space-between", marginBottom:12 }}>
                      <span style={{ fontSize:13, fontWeight:500 }}>{p.date}</span>
                      {p.checkpoint && <Badge color={T.mint}>{p.checkpoint}</Badge>}
                    </div>
                    <div style={{ display:"flex", gap:10 }}>
                      {p.weight && <StatBox label="น้ำหนัก" value={p.weight} unit="kg"/>}
                      {p.waist && <StatBox label="เอว" value={p.waist} unit="cm"/>}
                    </div>
                  </div>
                ))}
              </div>
            )}

          </div>

          {/* BOTTOM NAV */}
          <div style={{ position:"fixed", bottom:0, left:0, right:0, background:"rgba(255,255,255,0.9)", backdropFilter:"blur(20px)", borderTop:"1px solid rgba(0,0,0,0.03)", display:"flex", zIndex:50, paddingBottom:"env(safe-area-inset-bottom,0px)" }}>
            {[["dashboard","✨","Overview"],["log","📋","Log"],["progress","📏","Body"]].map(([k,icon,label])=>(
              <button key={k} onClick={()=>setTab(k)}
                style={{ flex:1, border:"none", background:"none", padding:"12px 0", cursor:"pointer", display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
                <span style={{ fontSize:22, filter:tab===k?"grayscale(0)":"grayscale(1) opacity(0.4)", transition:"0.2s" }}>{icon}</span>
                <span style={{ fontSize:10, color:tab===k?T.text:T.muted, fontWeight:tab===k?500:400 }}>{label}</span>
              </button>
            ))}
          </div>
        </div>
      );
    }

    ReactDOM.render(<App/>, document.getElementById("root"));
  </script>
</body>
</html>
